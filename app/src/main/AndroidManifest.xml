<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Activity Recognition: runtime on API 29+, normal (GMS) on API 28-. -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="com.google.android.gms.permission.ACTIVITY_RECOGNITION" />
    <!-- Notifying the user about a freshly detected trip (runtime on API 33+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- GPS trip distance: foreground while tracking; background to catch auto-detected trips. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!-- Persistent activity-tracking service (Activity Recognition satisfies the health type). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />
    <!-- Re-register tracking after a reboot. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CarbonWise">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.CarbonWise">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Receives Activity Transition results from Google Play Services. -->
        <receiver
            android:name=".recognition.ActivityTransitionReceiver"
            android:exported="false" />

        <!-- Handles notification quick-actions (one-tap log). -->
        <receiver
            android:name=".recognition.NotificationActionReceiver"
            android:exported="false" />

        <!-- Foreground service that measures trip distance via GPS. -->
        <service
            android:name=".recognition.TripLocationService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- Persistent service that keeps detection alive while auto-tracking is on. -->
        <service
            android:name=".recognition.TrackingService"
            android:exported="false"
            android:foregroundServiceType="health" />

        <!-- Re-registers tracking after device reboot. -->
        <receiver
            android:name=".recognition.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
